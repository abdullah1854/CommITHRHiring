# Database (Azure SQL Server via Prisma). Format:
# DATABASE_URL="sqlserver://HOST:1433;database=DB;user=USER;password=PASS;encrypt=true;trustServerCertificate=false"
# Example (UAT):
# DATABASE_URL="sqlserver://azstgdb01v.database.windows.net:1433;database=CorporateFormsDB_UAT;user=gbsqladmin;password=REPLACE_ME;encrypt=true;trustServerCertificate=false"
DATABASE_URL=

# Server
PORT=8080
SESSION_SECRET=your-strong-random-secret-here
NODE_ENV=production
# Where resume uploads are stored (absolute path). Default: <cwd>/uploads/resumes
# Set this if PM2 cwd is not the repo root or uploads should live on another drive.
# UPLOAD_RESUMES_DIR=D:\\apps\\aihr\\uploads\\resumes
# Session cookies: Secure (HTTPS-only) cookies in production unless set otherwise.
# Set to false when the API is served over plain HTTP (e.g. internal http://10.x.x.x:5500);
# otherwise browsers may not send cookies and you will see 401 / empty data.
SESSION_COOKIE_SECURE=true

# CORS - comma-separated allowed origins (leave empty for permissive mode in dev)
CORS_ORIGIN=https://yourdomain.com
# If you terminate TLS or proxy in front of Node (nginx, IIS), allow large multipart uploads, e.g.:
# client_max_body_size 25m;

# Frontend
# PORT=3000 (for the Vite dev server)
# BASE_PATH=/
# API_URL=http://localhost:8080

# AI / OpenAI
# If OPENAI_API_KEY (or AI_INTEGRATIONS_OPENAI_API_KEY) is not set, aiService returns mock stub
# responses so the UI stays functional for end-to-end testing without a key.
OPENAI_API_KEY=sk-your-key-here
# GPT-4o is the hard default base model for all AI calls (screening, summaries, interview questions,
# JD generation/improvement, resume parsing). Do not change unless you know the replacement supports
# the same chat.completions + response_format=json_object behavior.
OPENAI_MODEL=gpt-4o
# Optional: override base URL to swap providers (e.g., Azure OpenAI, OpenRouter). Falls back to
# AI_INTEGRATIONS_OPENAI_BASE_URL if OPENAI_BASE_URL is unset.
# OPENAI_BASE_URL=https://api.openai.com/v1
# Network behaviour
# OPENAI_TIMEOUT_MS=60000
# OPENAI_MAX_RETRIES=2
# Brand voice for AI-generated job descriptions (kept generic by default)
# AI_BRAND_NAME="Goldbell"
# AI_BRAND_VOICE="professional, governance-focused, emphasising ownership and measurable outcomes"
# AI_BRAND_LOCALE="British/Singapore English"
# Resume context window (characters) per AI call — bigger = more accurate, more cost
# AI_SCREEN_RESUME_CAP=18000
# AI_SUMMARY_RESUME_CAP=8000
# AI_QUESTIONS_RESUME_CAP=4000
# AI_PARSE_RESUME_CAP=8000
# AI_SKILL_EXTRACT_CAP=6000
# Sampling temperature: lower = more deterministic scoring (screening defaults to 0)
# AI_SCREEN_TEMPERATURE=0
# AI_GENERAL_TEMPERATURE=0.4
# Deterministic screening: same seed + temperature 0 → repeatable scores
# AI_SCREEN_SEED=42
# Bump if you change the screening prompt and want to invalidate cached results
# AI_SCREEN_PROMPT_VERSION=v3
# Where the file-based screening cache lives (auto-created). Default: <cwd>/.aihr-cache
# AI_SCREEN_CACHE_DIR=D:\\apps\\aihr\\.aihr-cache
# Soft cap on cached screening entries (oldest evicted first)
# AI_SCREEN_CACHE_MAX_ENTRIES=5000
# Token budgets per call type
# AI_SCREEN_MAX_TOKENS=4000
# AI_SUMMARY_MAX_TOKENS=4000
# AI_QUESTIONS_MAX_TOKENS=4000
# AI_JD_MAX_TOKENS=4000
# AI_PARSE_MAX_TOKENS=2000
# AI_SKILL_MAX_TOKENS=1000
# Screening rubric weights (auto-normalised to sum 100). Defaults shown below.
# AI_WEIGHT_REQUIRED=30
# AI_WEIGHT_RESPONSIBILITIES=20
# AI_WEIGHT_DOMAIN=15
# AI_WEIGHT_EXPERIENCE=10
# AI_WEIGHT_SENIORITY=10
# AI_WEIGHT_PREFERRED=10
# AI_WEIGHT_ACHIEVEMENTS=5

# Apify (optional — LinkedIn profile scraper)
# Get your token at https://console.apify.com/account/integrations
# If not set, LinkedIn verification is skipped (CV-only screening with a risk flag)
APIFY_TOKEN=apify_api_your_token_here

# Email (optional - mock mode if not set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-password
# SMTP_FROM="GIQ" <noreply@yourdomain.com>
