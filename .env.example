# =============================================================================
# Database — Supabase Postgres (project: qfcuisdluubwelihkbqf, schema: commit_hr)
# =============================================================================
# Two URLs by design:
#   DATABASE_URL → pooled (Supavisor, 6543) — runtime / Prisma queries.
#                  Use ?pgbouncer=true so Prisma disables prepared statements.
#   DIRECT_URL   → direct (5432) — Prisma migrate / shadow DB only.
# Replace [PROJECT_PASSWORD] with the database password (Supabase Studio →
# Project Settings → Database → Connection string).
# Region is set when the Supabase project was created; ap-southeast-1 = Singapore.
DATABASE_URL="postgresql://postgres.qfcuisdluubwelihkbqf:[PROJECT_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=commit_hr"
DIRECT_URL="postgresql://postgres.qfcuisdluubwelihkbqf:[PROJECT_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?schema=commit_hr"

# Supabase REST / Auth / Storage (used if/when Supabase SDK is wired)
SUPABASE_URL="https://qfcuisdluubwelihkbqf.supabase.co"
# Publishable (browser-safe) — fine to ship to frontend bundle
SUPABASE_PUBLISHABLE_KEY="sb_publishable_jBu4ghgPYO6c09rQoTBQOw_Q2-AJUrX"
# Service role (server-only — bypasses RLS). NEVER expose to frontend.
# Get from Supabase Studio → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY="REPLACE_ME"

# =============================================================================
# Server
# =============================================================================
PORT=8080
SESSION_SECRET=your-strong-random-secret-here
NODE_ENV=production
# Where resume uploads are stored (absolute path). Default: <cwd>/uploads/resumes
# UPLOAD_RESUMES_DIR=/var/lib/commit-hr/uploads/resumes
# Session cookies: Secure (HTTPS-only) cookies in production unless set otherwise.
SESSION_COOKIE_SECURE=true

# CORS - comma-separated allowed origins (leave empty for permissive mode in dev)
CORS_ORIGIN=https://yourdomain.com

# =============================================================================
# Frontend (Vite — VITE_* vars are exposed to the browser bundle)
# =============================================================================
# PORT=3000 (for the Vite dev server)
# BASE_PATH=/
# API_URL=http://localhost:8080
# Browser-side Supabase client. Use the publishable key, NEVER the service role.
VITE_SUPABASE_URL="https://qfcuisdluubwelihkbqf.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_jBu4ghgPYO6c09rQoTBQOw_Q2-AJUrX"

# =============================================================================
# AI — OpenAI (lite screening + JD/questions/summary/parse)
# =============================================================================
# If neither OPENAI_API_KEY nor AI_INTEGRATIONS_OPENAI_API_KEY is set,
# aiService returns mock stub responses so the UI stays functional.
OPENAI_API_KEY=sk-your-key-here
# Lite screening + JD + summary + interview questions + resume parsing
# Confirm exact model ID (gpt-5-mini / gpt-5.1-mini / gpt-5.4-mini) in OpenAI dashboard.
OPENAI_MODEL=gpt-5.4-mini
# Optional: override base URL (Azure OpenAI, OpenRouter, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_MS=60000
# OPENAI_MAX_RETRIES=2

# =============================================================================
# AI — Anthropic (deep screening on Claude Sonnet 4.6)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_DEEP_SCREENING_MODEL=claude-sonnet-4-6
# ANTHROPIC_TIMEOUT_MS=60000
# ANTHROPIC_MAX_RETRIES=2

# =============================================================================
# AI — Brand voice (COMM-iT Group, ASEAN IBM Maximo + Microsoft ERP partner)
# =============================================================================
AI_BRAND_NAME="COMM-iT Group"
AI_BRAND_VOICE="professional, ASEAN-regional, emphasising delivery track record, certified expertise, and long-term partnership"
AI_BRAND_LOCALE="British English (Malaysian/Singapore market)"

# Resume context window (characters) per AI call — bigger = more accurate, more cost
# AI_SCREEN_RESUME_CAP=18000
# AI_DEEP_SCREEN_RESUME_CAP=32000
# AI_SUMMARY_RESUME_CAP=8000
# AI_QUESTIONS_RESUME_CAP=4000
# AI_PARSE_RESUME_CAP=8000
# AI_SKILL_EXTRACT_CAP=6000
# Sampling temperature: lower = more deterministic scoring (screening defaults to 0)
# AI_SCREEN_TEMPERATURE=0
# AI_GENERAL_TEMPERATURE=0.4
# Deterministic screening: same seed + temperature 0 → repeatable scores
# AI_SCREEN_SEED=42
# Bump if you change the screening prompt and want to invalidate cached results
# AI_SCREEN_PROMPT_VERSION=v3
# Where the file-based screening cache lives (auto-created). Default: <cwd>/.aihr-cache
# AI_SCREEN_CACHE_DIR=/var/lib/commit-hr/.cache
# Soft cap on cached screening entries (oldest evicted first)
# AI_SCREEN_CACHE_MAX_ENTRIES=5000
# Token budgets per call type
# AI_SCREEN_MAX_TOKENS=4000
# AI_SUMMARY_MAX_TOKENS=4000
# AI_QUESTIONS_MAX_TOKENS=4000
# AI_JD_MAX_TOKENS=4000
# AI_PARSE_MAX_TOKENS=2000
# AI_SKILL_MAX_TOKENS=1000
# Screening rubric weights (auto-normalised to sum 100). Defaults shown below.
# AI_WEIGHT_REQUIRED=30
# AI_WEIGHT_RESPONSIBILITIES=20
# AI_WEIGHT_DOMAIN=15
# AI_WEIGHT_EXPERIENCE=10
# AI_WEIGHT_SENIORITY=10
# AI_WEIGHT_PREFERRED=10
# AI_WEIGHT_ACHIEVEMENTS=5

# =============================================================================
# Apify (optional — LinkedIn profile scraper)
# =============================================================================
# Get your token at https://console.apify.com/account/integrations
# If not set, LinkedIn verification is skipped (CV-only screening with a risk flag)
APIFY_TOKEN=apify_api_your_token_here

# =============================================================================
# Email (optional — mock mode if not set)
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-password
# SMTP_FROM="COMM-iT Hiring" <noreply@comm-itgroup.com>
